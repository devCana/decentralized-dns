# Resolver Server configuration (HLD §4.4). Copy to .env and adjust; a local
# .env is loaded automatically at startup (real env vars take precedence).
RPC_URL=http://127.0.0.1:8545

# Contract addresses. Leave blank to auto-detect from the deploy artifact at
# $DEPLOYMENTS (default ../contracts/deployments/localhost.json), which
# `make deploy-localhost` writes — so local runs need no manual copying.
CONTRACT_ADDRESS=
REGISTRY_ADDRESS=
# DEPLOYMENTS=../contracts/deployments/localhost.json
RESOLVER_KEYSTORE=resolver.key
REST_PORT=8080
# UDP query port. 5353 collides with mDNS/Bonjour on macOS — the resolver just
# logs a warning and runs REST-only; set another port (e.g. 5354) to enable UDP.
UDP_PORT=5353
BT_LISTEN_PORT=42069
CACHE_SIZE=4096
DATA_DIR=./data

# Per-IP REST rate limit (requests/second) and burst allowance.
RATE_RPS=20
RATE_BURST=40

# Honour client-supplied ?peer= hints on /resource (trusted/local networks
# only — enabling this lets callers ask the resolver to dial arbitrary peers).
ALLOW_PEER_HINTS=false

# Resource Type Validation (FS §2.2): when true, the resolver refuses to serve
# a ResourceRef whose bytes do not match its declared content type. When false
# (default) a mismatch is only flagged via the X-DDNS-Content-Validation header
# and a log warning; ddns-fetch re-checks it trustlessly either way.
ENFORCE_CONTENT_TYPE=false
